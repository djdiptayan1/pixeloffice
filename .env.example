# ===========================================================================
# PixelOffice — environment configuration (ALL OPTIONAL).
#
# The zero-config path is sacred: with NONE of these set, `npm install &&
# npm run dev` runs the full MVP — dev login, in-memory storage, mock calendar,
# mock GreytHR, open admin console, ephemeral JWT. Everything below is opt-in.
# Copy this file to `.env` and uncomment only what you need. Never commit real
# secrets — the values here are placeholders/examples.
# ===========================================================================

# ---- Core server ----------------------------------------------------------
# Port the server (REST + Colyseus ws) listens on. Default 2567.
# PORT=2567

# Idle timeout before a session auto-flips to AWAY (source AUTO), in ms. Any C2S
# message counts as activity and clears it. Default 90000 (90s).
# AWAY_TIMEOUT_MS=90000

# Server log verbosity. One of: debug | info | warn | error. Default info.
# (Operational events only — never chat, movement, or per-user activity.)
# LOG_LEVEL=info

# ---- Ambient NPCs (OPTIONAL tuning; defaults give a lively office) ---------
# Server-driven ambient office NPCs so the room never feels empty. They wander,
# take coffee breaks, occasionally drift to a live social event, and RARELY
# chat. They are ambience only: NPCs never join meetings, never touch HR, never
# respond to humans, and never auto-move a real avatar (human agency holds).
#
# Number of NPCs to spawn. Default 8 (spread across all four departments).
# Set 0 to disable NPCs entirely; clamped to a maximum of 16. NPCs take the LAST
# desk seats per department, always leaving the first 2 seats free for humans.
# NPC_COUNT=8
#
# Seed for the NPC behavior PRNG. Same seed => identical, reproducible behavior
# (used for deterministic tests). Default 42.
# NPC_SEED=42

# ---- Auth (unset = dev mode: dev login, open admin, ephemeral JWT) ---------
# Application JWT signing secret. Unset => an ephemeral per-process secret is
# generated and a boot warning is logged (tokens reset on restart). Set a long
# random value in production so tokens survive restarts.
# JWT_SECRET=

# Token lifetime (jsonwebtoken format, e.g. 12h, 7d, 3600). Default "12h".
# JWT_EXPIRES_IN=12h

# Require a valid JWT to JOIN the office room AND a valid ADMIN JWT for admin
# REST writes. Leave false/unset for the zero-config dev experience.
# AUTH_REQUIRED=false

# Comma-separated emails granted the 'admin' role (RBAC). Everyone else is
# 'member'. The dev login user is never an admin unless they OAuth in with one
# of these emails.
# ADMIN_EMAILS=admin@example.com

# Where the browser is redirected after a successful OAuth callback (the client
# app origin). Default http://localhost:5173.
# CLIENT_APP_URL=http://localhost:5173

# Department assigned to OAuth users who do not pick one at the login screen.
# DEFAULT_DEPARTMENT=Engineering

# Restrict OAuth sign-in to these email domains (comma-separated). Unset = no
# restriction (any verified Google/Microsoft account may join). Set this in
# production so arbitrary external accounts cannot enter the company office.
# ALLOWED_EMAIL_DOMAINS=kalvium.com

# Public base URL of THIS server. OAuth redirect URIs are
# ${OAUTH_REDIRECT_BASE}/api/auth/<provider>/callback . Required to enable any
# OAuth provider. Use an https URL in production.
# OAUTH_REDIRECT_BASE=http://localhost:2567

# ---- Google OAuth (enable by setting BOTH id + secret AND the redirect base) -
# Register redirect URI: ${OAUTH_REDIRECT_BASE}/api/auth/google/callback
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# ---- Google Calendar -> Presence + Meet (OPTIONAL integration) ------------
# Reuses the SAME GOOGLE_CLIENT_ID / GOOGLE_CLIENT_SECRET above. When BOTH are
# set, the server overlays a real GoogleCalendarAdapter on the mock calendar
# (admin-scheduled dev meetings keep working AND real Google meetings drive
# IN_MEETING presence + a "Join" Meet link). With them unset, the calendar stays
# the pure mock and these routes 404 — the zero-config dev path is untouched.
#
# Scope requested (least privilege): calendar.events.readonly. The connect flow
# is an INCREMENTAL offline grant (access_type=offline, prompt=consent) and the
# per-user refresh token is stored server-side, keyed by stable identity. The
# client's "Connect Google Calendar" button hits:
#   GET  /api/auth/google/calendar/connect?sessionId=...
#   GET  /api/auth/google/calendar/callback  (Google redirects here)
#   GET  /api/auth/google/calendar/status?sessionId=...   -> { connected }
#   POST /api/auth/google/calendar/disconnect
# Register this redirect URI too:
#   ${OAUTH_REDIRECT_BASE}/api/auth/google/calendar/callback
#
# Read titles? Default true. Set false for busy/free-only privacy mode: meetings
# display "Busy" instead of the event title (no-surveillance friendly).
# GOOGLE_CAL_TITLES=true
#
# Background poll interval per connected user, in ms. Default 45000 (~1-2
# req/user/min, far under quota). Lower = fresher presence, more API calls.
# GOOGLE_CAL_POLL_MS=45000
#
# Endpoint base overrides — point these at a LOCAL STUB to run the whole Google
# flow offline (tests / dev without a real Google project). Defaults are the
# real Google endpoints; leave unset in production.
#   GOOGLE_AUTH_BASE  default https://accounts.google.com   (consent screen)
#   GOOGLE_TOKEN_BASE default https://oauth2.googleapis.com (code + refresh mint)
#   GOOGLE_API_BASE   default https://www.googleapis.com    (events.list)
# GOOGLE_AUTH_BASE=https://accounts.google.com
# GOOGLE_TOKEN_BASE=https://oauth2.googleapis.com
# GOOGLE_API_BASE=https://www.googleapis.com

# ---- Microsoft OAuth / Azure AD (enable like Google; needs the redirect base) -
# Register redirect URI: ${OAUTH_REDIRECT_BASE}/api/auth/microsoft/callback
# MS_CLIENT_ID=
# MS_CLIENT_SECRET=
# Tenant id, or one of: common | organizations | consumers. Default "common".
# MS_TENANT=common

# ---- GreytHR / Attendance (OPTIONAL integration) --------------------------
# Activate the REAL GreytHR adapter by setting GREYTHR_BASE_URL plus EITHER an
# API user + key (preferred — the adapter acquires & auto-refreshes an OAuth2
# access token) OR a pre-acquired bearer token (legacy GREYTHR_API_TOKEN).
# Without these the in-memory mock is used and the office still works
# (integrations are optional). A dead/fake config degrades gracefully — HR calls
# return errors and the office is unaffected.
#
# Auth + endpoints are based on greytHR's official API platform:
#   https://api-docs.greythr.com/  |  https://greythr-api-docs.readthedocs.io/
#   POST {base}/uas/v1/oauth2/client-token -> { access_token, expires_in };
#   subsequent calls send Access-Token + x-greythr-domain headers.
#
# Company-domain base (kalvium): https://kalvium.greythr.com (the generic
# https://api.greythr.com also serves the API). The x-greythr-domain header
# defaults to the host of GREYTHR_BASE_URL.
# GREYTHR_BASE_URL=https://kalvium.greythr.com
#
# Preferred: API user (client id) + API key (client secret) created by a greytHR
# admin under Settings > My Account > API Details. The adapter caches the token
# and refreshes it before expiry; a 401 triggers exactly one refresh + retry.
# GREYTHR_API_USER=Apiuser
# GREYTHR_API_KEY=your-api-key
#
# Legacy alternative: a pre-acquired bearer token (no auto-refresh; a 401 simply
# degrades gracefully). Ignored if API_USER + API_KEY are set.
# GREYTHR_API_TOKEN=your-bearer-token
#
# ESS portal deep link shown in the attendance widget ("Open greytHR"). Defaults
# to the kalvium ESS home when GreytHR is configured; absent otherwise (the
# client hides the link).
# GREYTHR_PORTAL_URL=https://kalvium.greythr.com/v3/portal/ess/home
#
# Per-request timeout in ms (default 5000).
# GREYTHR_TIMEOUT_MS=5000

# ---- Persistence (Layer 4 — OPTIONAL; unset = in-memory, zero-config) ------
# Set & reachable => PostgreSQL user storage (auto-migrated). Set but DOWN =>
# a warning is logged and the office falls back to in-memory (never crashes).
# DATABASE_URL=postgres://pixeloffice:pixeloffice@localhost:5432/pixeloffice
# Run db/init.sql on boot (idempotent). Default true when DATABASE_URL is set;
# set false to manage the schema yourself.
# AUTO_MIGRATE=true
# TLS for Postgres. Most managed providers (RDS/Heroku/Supabase/Neon/Render)
# REQUIRE it. Honored from the URL's ?sslmode=... first; otherwise from this:
#   require (verify CA) | no-verify (encrypt, skip CA verify) | disable
# DATABASE_SSL=require

# Set & reachable => Redis presence storage. Set but DOWN => warn + in-memory.
# REDIS_URL=redis://localhost:6379

# ---- Single-container / production serving (OPTIONAL) ----------------------
# Serve the built client (client/dist) from Express on the same port as the API
# + ws transport. Off by default (dev uses the Vite server on :5173). The Docker
# image sets this to true. If on with no build present, the server logs a warning
# and serves API only.
# SERVE_CLIENT=true

# ---- REST rate limiting (OPTIONAL tuning) ---------------------------------
# Token-bucket per client IP on /api. GET /api/health is never throttled.
# API_RATE_LIMIT=60
# API_RATE_WINDOW_MS=60000

# Trust a vetted reverse proxy in front of the server (the single-container prod
# deploy). When true the rate limiter keys off the real client IP (X-Forwarded-
# For) instead of collapsing every user into the proxy's single bucket. Leave
# unset/false when the server is directly exposed (XFF is attacker-controlled).
# TRUST_PROXY=true

# ---- CORS (OPTIONAL) ------------------------------------------------------
# Comma-separated allowed browser origins for /api. Defaults to CLIENT_APP_URL
# (or http://localhost:5173). Never use a wildcard in production — it lets any
# site a logged-in user visits read the API cross-origin.
# CORS_ORIGINS=http://localhost:5173
