# ===========================================================================
# PixelOffice — environment configuration (ALL OPTIONAL).
#
# Zero-config is sacred: with NONE of these set, `npm install && npm run dev`
# runs the full MVP (dev login, in-memory storage, mock calendar/HR, open admin,
# ephemeral JWT). Copy to `.env` and uncomment only what you need. Never commit
# real secrets.
# ===========================================================================

# ---- Core server ----------------------------------------------------------
# PORT=2567                       # REST + Colyseus ws port (default 2567)
# AWAY_TIMEOUT_MS=90000           # idle -> AWAY (any C2S msg clears it)
# LOG_LEVEL=info                  # debug | info | warn | error

# ---- Ambient NPCs ----------------------------------------------------------
# Server-driven ambient avatars so the office never feels empty (ambience only:
# never join meetings/HR, never respond to humans, never move a real avatar).
# NPC_COUNT=8                     # 0 disables; clamped to 16
# NPC_SEED=42                     # PRNG seed (same seed => reproducible)

# ---- Auth (unset = dev login, open admin, ephemeral JWT) -------------------
# JWT_SECRET=                     # set a long random value in production
# JWT_EXPIRES_IN=12h              # jsonwebtoken format (12h, 7d, 3600)
# AUTH_REQUIRED=false             # require a valid JWT to join + admin writes
# ADMIN_EMAILS=admin@example.com  # comma-separated emails granted 'admin'
# CLIENT_APP_URL=http://localhost:5173   # post-OAuth redirect (client origin)
# DEFAULT_DEPARTMENT=Engineering         # dept for OAuth users who don't pick
# ALLOWED_EMAIL_DOMAINS=kalvium.com      # restrict OAuth sign-in (comma list)
# OAUTH_REDIRECT_BASE=http://localhost:2567  # required for ANY OAuth provider;
#                                 # callbacks: ${OAUTH_REDIRECT_BASE}/api/auth/<provider>/callback

# ---- Google OAuth + Calendar -> Presence/Meet (OPTIONAL) -------------------
# Set BOTH id+secret AND OAUTH_REDIRECT_BASE. Register redirect URIs:
#   ${OAUTH_REDIRECT_BASE}/api/auth/google/callback
#   ${OAUTH_REDIRECT_BASE}/api/auth/google/calendar/callback
# When set, real Google meetings drive IN_MEETING presence + a Join link;
# unset keeps the pure mock calendar (zero-config path untouched).
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_CAL_TITLES=true          # false = busy/free only (privacy mode)
# GOOGLE_CAL_POLL_MS=45000        # per-user calendar poll interval
# Endpoint overrides — point at a local stub to run Google flows offline:
# GOOGLE_AUTH_BASE=https://accounts.google.com
# GOOGLE_TOKEN_BASE=https://oauth2.googleapis.com
# GOOGLE_API_BASE=https://www.googleapis.com

# ---- Microsoft OAuth / Azure AD (OPTIONAL) ---------------------------------
# Register redirect URI: ${OAUTH_REDIRECT_BASE}/api/auth/microsoft/callback
# MS_CLIENT_ID=
# MS_CLIENT_SECRET=
# MS_TENANT=common                # or organizations | consumers | <tenant id>

# ---- greytHR: login + attendance (OPTIONAL) --------------------------------
# SINGLE EGRESS — PixelOffice NEVER talks to greytHR's website/cloud directly.
# ALL greytHR interaction (sign-in, sign-out, attendance check-in/out, profile)
# goes through ONE custom, team-built ESS API at GREYTHR_CLIENT_URL — that API
# is the ONLY source of truth for greytHR. PixelOffice never stores the password:
# it forwards it once to that API and keeps only the JWT it mints. OFF by default
# (the zero-config dev login card shows unless GREYTHR_LOGIN_ENABLED=true).
#
# GREYTHR_LOGIN_ENABLED=true
# GREYTHR_CLIENT_URL=https://greythr.example.in  # the custom ESS API (single egress)
# GREYTHR_SUBDOMAIN=kalvium                      # company subdomain (prefilled in the form)
# GREYTHR_LOGIN_TIMEOUT_MS=8000                  # login call timeout (login is slow)
# GREYTHR_PORTAL_URL=https://kalvium.greythr.com/v3/portal/ess/home  # user-facing "Open greytHR" link only

# ---- Persistence (OPTIONAL; unset = in-memory) -----------------------------
# Set & reachable => real backend; set but DOWN => warn + in-memory (never crash).
# DATABASE_URL=postgres://pixeloffice:pixeloffice@localhost:5432/pixeloffice
# AUTO_MIGRATE=true               # run db/init.sql on boot (default true if URL set)
# DATABASE_SSL=require            # require | no-verify | disable (managed PG needs TLS)
# REDIS_URL=redis://localhost:6379   # Redis presence storage

# ---- Production serving / proxy / CORS (OPTIONAL) --------------------------
# SERVE_CLIENT=true               # serve client/dist from Express (Docker sets this)
# API_RATE_LIMIT=60               # token-bucket per IP on /api (health never throttled)
# API_RATE_WINDOW_MS=60000
# TRUST_PROXY=true                # honor X-Forwarded-For (ONLY behind a vetted proxy)
# CORS_ORIGINS=http://localhost:5173    # comma-separated; never wildcard in prod

# ---- OPT-IN physical-floor detection (OPTIONAL; OFF by default) ------------
# When a user explicitly enables floor sync in Settings, the server maps their
# client IP to an Office/Remote tag (and, when Office, a floor). SENSITIVE, so
# inert unless OFFICE_SUBNETS/OFFICE_CIDRS are set. PRIVACY: only the current
# tag + floor are kept — never the IP, never a location history. IPv4 only.
# OFFICE_SUBNETS=10.1.0.0/16=floor-1,10.2.0.0/16=floor-2,10.0.0.0/16=ground
# OFFICE_CIDRS=203.0.113.0/24            # office ranges with no specific floor
#
# Companion SSID helper (browsers can't read WiFi SSID): a per-machine helper
# POSTs the SSID to /api/location/floor-report; the server maps it to a floor and
# applies it ONLY to opted-in users. See docs/SSID-FLOOR-SYNC.md.
# SSID_FLOOR_MAP=KALVIUMGF=ground,KALVIUM1F=floor-1,KALVIUM2F=floor-2  # substring=floorId, first match wins
# FLOOR_SYNC_SECRET=              # optional shared secret the companion must send
